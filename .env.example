# --- GoTo Connect OAuth client (developer.logmeininc.com/clients) ---
GOTO_CLIENT_ID=
GOTO_CLIENT_SECRET=

# --- GoTo Connect Personal Access Token (myaccount.goto.com > Developer tools) ---
# Long-lived. Exchanged at runtime for short-lived access tokens.
GOTO_PAT=

# --- GoTo account key ---
# Leave blank and `npm run setup` will fetch it for you from /admin/rest/v1/me
GOTO_ACCOUNT_KEY=

# --- Fireflies.ai ---
FIREFLIES_API_KEY=

# --- Public URL of THIS service (must be internet-reachable, HTTPS in production) ---
# Used both as the GoTo webhook target and to build public URLs for staged recordings.
PUBLIC_BASE_URL=https://your-domain.example.com

# --- Server ---
PORT=3001

# --- Storage backend for staging recordings so Fireflies can fetch them ---
# "local"  = serve the file from this server at a random one-time URL (default, no extra signup)
# "s3"     = upload to an S3 bucket and use a presigned URL
STORAGE_BACKEND=local

# Only needed if STORAGE_BACKEND=s3
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
