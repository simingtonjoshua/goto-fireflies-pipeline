# --- GoTo Connect OAuth client (developer.logmeininc.com/clients) ---
GOTO_CLIENT_ID=
GOTO_CLIENT_SECRET=

# --- GoTo Connect Personal Access Token (myaccount.goto.com > Developer tools) ---
# Long-lived. Exchanged at runtime for short-lived access tokens.
GOTO_PAT=

# --- GoTo account key ---
# Leave blank and `npm run setup` will fetch it for you from /users/v1/me
GOTO_ACCOUNT_KEY=

# --- Google Drive archival (src/driveClient.js) ---
# OAuth2 client + refresh token authorized as jsimington@budgetblinds.com with the
# minimal, non-sensitive `drive.file` scope via Google's OAuth 2.0 Playground.
# GOOGLE_DRIVE_FOLDER_ID is the "Call Recordings" folder this app created - every
# archived recording lands there.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=

# --- OpenAI (for the upcoming call-summary step) ---
OPENAI_API_KEY=

# --- Public URL of THIS service (must be internet-reachable, HTTPS in production) ---
# Used as the GoTo webhook target.
PUBLIC_BASE_URL=https://your-domain.example.com

# --- Server ---
PORT=3001
