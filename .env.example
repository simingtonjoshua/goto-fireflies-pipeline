# --- GoTo Connect OAuth client (developer.logmeininc.com/clients) ---
GOTO_CLIENT_ID=
GOTO_CLIENT_SECRET=

# --- GoTo Connect Personal Access Token (myaccount.goto.com > Developer tools) ---
# Long-lived. Exchanged at runtime for short-lived access tokens.
GOTO_PAT=

# --- GoTo account key ---
# Leave blank and `npm run setup` will fetch it for you from /users/v1/me
GOTO_ACCOUNT_KEY=

# --- Google Drive archival (src/driveClient.js) ---
# OAuth2 client + refresh token authorized as jsimington@budgetblinds.com with the
# minimal, non-sensitive `drive.file` scope via Google's OAuth 2.0 Playground.
# GOOGLE_DRIVE_FOLDER_ID is the "Call Recordings" folder this app created - every
# archived recording lands there.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=

# --- OpenAI (src/openaiClient.js - summarizes each finalized interaction) ---
OPENAI_API_KEY=
# Optional, defaults to gpt-4o-mini
OPENAI_MODEL=

# --- Heymarket (src/heymarketClient.js - posts each summary as a private note) ---
# API Secret ID/Key from Heymarket's Settings > Integrations > API, used to sign a
# short-lived JWT per request (see https://developers.heymarket.com/authentication).
# HEYMARKET_INBOX_ID and HEYMARKET_CREATOR_ID come from that same account's
# GET /v1/inboxes response - creator_id is the sending member id, not a general user id.
HEYMARKET_API_SECRET_ID=
HEYMARKET_API_SECRET_KEY=
HEYMARKET_INBOX_ID=
HEYMARKET_CREATOR_ID=

# --- Public URL of THIS service (must be internet-reachable, HTTPS in production) ---
# Used as the GoTo webhook target.
PUBLIC_BASE_URL=https://your-domain.example.com

# --- Server ---
PORT=3001
